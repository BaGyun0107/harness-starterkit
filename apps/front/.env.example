# ══════════════════════════════════════════════════════════════════════════
# Frontend 환경변수 예시 (Next.js 15 App Router)
# ══════════════════════════════════════════════════════════════════════════
#
# 사용처:
#   1. 최초 로컬 개발 — 이 파일을 복사해서 .env.development / .env.production 생성
#      cp .env.example .env.development
#
#   2. Infisical 전환 시 — 이 파일의 내용을 그대로 Infisical 에 업로드
#      - [런타임] 섹션                → /frontend/
#      - [배포 - Vercel] 섹션         → /frontend/github-actions/  (Vercel 사용 시)
#      - [배포 - PM2/Static] 섹션     → /frontend/github-actions/  (인스턴스 서버 사용 시)
#
#      ※ 배포 방식이 확정되면 해당 섹션만 업로드하면 된다.
#        Vercel / PM2 / Static / Docker 중 어느 경로를 선택했느냐에 따라 갈림
#
# 참고 문서:
#   - API 호출 규칙:        .agents/skills/oma-frontend/resources/api-convention.md
#   - 프로젝트 레이아웃:    .agents/skills/oma-frontend/stack/tech-stack.md
#   - 배포 워크플로우:      .github/workflows/deploy-frontend-*.yml
#   - 배포 방식 선택:       .claude/skills/init-project/references/deploy-methods.md
#
# 주의:
#   - NEXT_PUBLIC_* 접두사: 브라우저에 노출됨 → 시크릿 값은 절대 붙이지 말 것
#   - 서버 전용 변수는 접두사 없이 작성 → 서버 컴포넌트/라우트 핸들러에서만 사용
#   - 실제 값은 커밋 금지. .env.development / .env.production 은 .gitignore 처리됨
# ══════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────
# [런타임] Frontend 앱 실행 시 필요한 값들
#   Infisical 경로: /frontend/
#   Vercel 사용 시: Infisical → Vercel Integration 으로 자동 동기화
#   npm run dev 시 infisical run 이 주입
# ─────────────────────────────────────────────────────────

# ─── 앱 기본 ───
# 프론트 자체 URL (미들웨어/메타 태그/절대 링크 생성 시 사용)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── 백엔드 API ───
# 브라우저에서 호출할 API 베이스 URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# (선택) 서버 컴포넌트 전용 내부 API URL
# 같은 VPC/네트워크 내에서 호출하는 경우 브라우저용과 다를 수 있음
# API_URL_INTERNAL=http://backend-internal:8080

# ─── 환경 표기 ───
# UI 상단 배너/분기 로직 등에 사용 (development | production)
NEXT_PUBLIC_APP_ENV=development


# ─────────────────────────────────────────────────────────
# [배포 — Vercel] Vercel CLI 로 배포할 때 사용하는 값들
#   Infisical 경로: /frontend/github-actions/
#   deploy-frontend-vercel.yml 워크플로우에서 사용
# ─────────────────────────────────────────────────────────

# Vercel 대시보드에서 확인 (Settings → General)
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=


# ─────────────────────────────────────────────────────────
# [배포 — PM2 / Static] 인스턴스 서버로 배포할 때 사용하는 값들
#   Infisical 경로: /frontend/github-actions/
#   deploy-frontend-pm2.yml 워크플로우에서 사용
#   FRONT_APP_TYPE 에 따라 재시작 방식이 달라짐:
#     pm2    : Next.js SSR 등 Node.js 런타임 → PM2 재시작
#     static : React SPA 등 정적 파일 → current/ 교체만 (Nginx 자동 반영)
# ─────────────────────────────────────────────────────────

FRONT_SERVER_HOST=10.0.10.22
FRONT_SERVER_USER=rocky
FRONT_DEPLOY_DIR=/home/rocky/CODI.my-app-front-dev

# PM2 앱 이름 (FRONT_APP_TYPE=pm2 일 때만 의미 있음. static 모드에서도 로그용으로 사용)
FRONT_APP_NAME=codi-my-app-front-dev

# 빌드 후 전송할 tar 파일명
FRONT_TAR_FILE=codi_my_app_front_dev.tar.gz

# SSH 개인키 (PEM 포맷 전체를 그대로 입력)
FRONT_SSH_PRIVATE_KEY=

# 배포 방식
#   pm2    : Next.js SSR — PM2 재시작
#   static : React SPA / 정적 파일 — PM2 건너뜀 (Nginx 자동 반영)
FRONT_APP_TYPE=pm2


# ─────────────────────────────────────────────────────────
# [공용 — Shared-Secrets]
#   Infisical: 별도 Shared-Secrets 프로젝트
#   여러 프로젝트가 공유하는 값이므로 프로젝트별로 반복 등록하지 않음
#   새 프로젝트를 시작할 때 Machine Identity 에 Shared-Secrets 접근 권한만 부여하면 됨
# ─────────────────────────────────────────────────────────

# /slack/ 경로
# slack_bot_token=xoxb-...
# slack_channel=#dev-deploy-log

# /vercel/ 경로 (Vercel 배포 시만)
# VERCEL_TOKEN=...
