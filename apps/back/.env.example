# ══════════════════════════════════════════════════════════════════════════
# Backend 환경변수 예시 (Express 5 + Prisma + JWT 3-토큰 인증)
# ══════════════════════════════════════════════════════════════════════════
#
# 사용처:
#   1. 최초 로컬 개발 — 이 파일을 복사해서 .env.development / .env.production 생성
#      cp .env.example .env.development
#
#   2. Infisical 전환 시 — 이 파일의 내용을 그대로 Infisical 에 업로드
#      - [런타임] 섹션  → /backend/
#      - [배포]  섹션  → /backend/github-actions/
#
# 참고 문서:
#   - 런타임 스키마 + Zod 검증: .agents/skills/oma-backend/resources/config-reference.md
#   - 인증/쿠키 구조:            .agents/skills/oma-backend/resources/auth-reference.md
#   - 배포 워크플로우:           .github/workflows/deploy-backend-pm2.yml
#
# 주의:
#   - 실제 값은 절대 이 파일에 커밋하지 말 것
#   - .env.development, .env.production 은 .gitignore 처리됨
#   - BACK_SSH_PRIVATE_KEY 같은 민감 값은 반드시 Infisical 또는 안전한 경로에서만 관리
# ══════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────
# [런타임] Backend 앱 실행 시 필요한 값들
#   Infisical 경로: /backend/
#   npm run dev 시 infisical run 이 주입
# ─────────────────────────────────────────────────────────

# ─── 서버 기본 ───
NODE_ENV=development
PORT=8080

# ─── 데이터베이스 (Prisma) ───
DATABASE_URL="mysql://user:password@localhost:3306/my_app_dev?connection_limit=10"

# ─── JWT 3-토큰 시크릿 ───
# openssl rand -base64 64 로 생성 권장. 토큰별로 다른 값 사용.
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_CSRF_SECRET=change-me-csrf-secret

# 토큰 만료 시간 ("15m", "7d" 형식)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS / 쿠키 ───
# 프론트 Origin (콤마 구분으로 여러 개 지정 가능)
CORS_ORIGIN=http://localhost:3000

# 쿠키 설정
COOKIE_DOMAIN=localhost
COOKIE_SAMESITE=lax

# ─── 로깅 (Pino) ───
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info


# ─────────────────────────────────────────────────────────
# [배포] GitHub Actions 가 서버로 배포할 때 사용하는 값들
#   Infisical 경로: /backend/github-actions/
#   로컬 개발에는 필요 없음 — 배포 전환 시점에 Infisical 에 등록
# ─────────────────────────────────────────────────────────

# 배포 대상 서버 접속 정보
BACK_SERVER_HOST=10.0.10.22
BACK_SERVER_USER=rocky
BACK_DEPLOY_DIR=/home/rocky/CODI.my-app-back-dev

# PM2 앱 이름 (ecosystem.config.js 의 name 과 일치)
BACK_APP_NAME=codi-my-app-back-dev

# 빌드 후 전송할 tar 파일명
BACK_TAR_FILE=codi_my_app_back_dev.tar.gz

# SSH 개인키 (PEM 포맷 전체를 그대로 입력)
# -----BEGIN OPENSSH PRIVATE KEY-----
# ...
# -----END OPENSSH PRIVATE KEY-----
BACK_SSH_PRIVATE_KEY=

# 배포 방식 (선택, 기본 pm2)
#   pm2    : Node.js 런타임 — PM2 재시작
#   static : 정적 파일 — PM2 단계 건너뜀 (백엔드에서는 거의 안 씀)
BACK_APP_TYPE=pm2
